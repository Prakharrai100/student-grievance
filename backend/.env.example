# ============================================================
# Backend Environment Variables — Copy this to .env
# On Render: set these in Dashboard > Your Service > Environment
# ============================================================

# Server Port (Render sets this automatically, but keep for local)
PORT=5000

# MongoDB Atlas URI
MONGO_URI=mongodb+srv://<username>:<password>@cluster0.xxxxx.mongodb.net/student_grievance?retryWrites=true&w=majority

# JWT Secret — use a long random string in production!
JWT_SECRET=your_super_secret_jwt_key_change_this_in_production

# Frontend URL on Render (for CORS) — e.g. https://grieveease.onrender.com
# Leave empty for local dev
FRONTEND_URL=https://your-frontend-app.onrender.com

# Environment
NODE_ENV=production
